---
const links = [
  { href: '#do-an',    label: '🍚 Đồ ăn' },
  { href: '#thuc-uong', label: '🥤 Thức uống' },
  { href: '#reviews',  label: '⭐ Đánh giá' },
  { href: '#map',      label: '📍 Bản đồ' },
  { href: '#lien-he',  label: '📞 Liên hệ' },
];
---

<nav class="sticky-nav" aria-label="Điều hướng nhanh">
  <ul class="sticky-nav__list">
    {links.map(l => (
      <li><a href={l.href} class="sticky-nav__link">{l.label}</a></li>
    ))}
  </ul>
</nav>

<script>
  const nav = document.querySelector('.sticky-nav') as HTMLElement;
  const links = nav.querySelectorAll<HTMLAnchorElement>('.sticky-nav__link');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        links.forEach(a => {
          a.classList.toggle('is-active', a.getAttribute('href') === `#${id}`);
        });
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });

  document.querySelectorAll('section[id], div[id]').forEach(el => observer.observe(el));
</script>

<style>
  .sticky-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
  }

  .sticky-nav__list {
    display: flex;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
    scrollbar-width: none;
    max-width: 900px;
    margin-inline: auto;
  }

  .sticky-nav__list::-webkit-scrollbar { display: none; }

  .sticky-nav__link {
    display: block;
    padding: 12px 16px;
    font-size: .82rem;
    font-weight: 600;
    color: #555;
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color .15s, border-color .15s;
  }

  .sticky-nav__link:hover,
  .sticky-nav__link.is-active {
    color: #ea580c;
    border-bottom-color: #ea580c;
  }
</style>
