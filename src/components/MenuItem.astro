---
import type { MenuItem } from '../data/menu';
import { discountedPrice } from '../data/menu';

interface Props {
  item: MenuItem;
}

const { item } = Astro.props;

const tagLabels: Record<string, string> = {
  bestseller: '🔥 Bán chạy',
  mới: '✨ Mới',
  chay: '🌿 Chay',
  cay: '🌶️ Cay',
  'ít cay': '🌶️ Ít cay',
};

const finalPrice = discountedPrice(item);
const hasDiscount = item.discount && item.discount > 0;
const isSoldOut = item.soldOut === true;
---

<div class={`menu-item${isSoldOut ? ' menu-item--sold-out' : ''}`}>
  <div class="menu-item__image-wrap">
    <img src={item.image} alt={item.name} loading="lazy" />
    {isSoldOut && <div class="sold-out-overlay">Hết hôm nay</div>}
    {!isSoldOut && hasDiscount && (
      <span class="badge badge--discount">-{item.discount}%</span>
    )}
    {item.type === 'combo' && (
      <span class="badge badge--combo">Combo</span>
    )}
  </div>

  <div class="menu-item__body">
    <div class="menu-item__tags">
      {(item.tags ?? []).map(tag => (
        <span class="tag">{tagLabels[tag] ?? tag}</span>
      ))}
    </div>

    <h3 class="menu-item__name">{item.name}</h3>
    <p class="menu-item__desc">{item.description}</p>

    {item.type === 'combo' && (
      <ul class="menu-item__includes">
        {item.includes.map(i => <li>{i}</li>)}
      </ul>
    )}

    <div class="menu-item__price">
      {hasDiscount && (
        <span class="price--original">
          {item.price.toLocaleString('vi-VN')}đ
        </span>
      )}
      <span class="price--final">
        {finalPrice.toLocaleString('vi-VN')}đ
      </span>
    </div>
  </div>
</div>

<style>
  .menu-item {
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
    display: flex;
    flex-direction: column;
  }

  .menu-item__image-wrap {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #f5f5f5;
  }

  .menu-item__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .badge {
    position: absolute;
    top: 8px;
    padding: 3px 8px;
    border-radius: 20px;
    font-size: .72rem;
    font-weight: 700;
    color: #fff;
  }

  .badge--discount {
    right: 8px;
    background: #e53935;
  }

  .badge--combo {
    left: 8px;
    background: #6c3eb8;
  }

  .sold-out-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.55);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: .95rem;
    font-weight: 700;
    letter-spacing: .5px;
  }

  .menu-item--sold-out {
    opacity: .75;
  }

  .menu-item--sold-out .price--final {
    color: #aaa;
  }

  .menu-item__body {
    padding: 12px 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .menu-item__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .tag {
    font-size: .7rem;
    padding: 2px 7px;
    border-radius: 20px;
    background: #fef3c7;
    color: #92400e;
    font-weight: 600;
  }

  .menu-item__name {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .menu-item__desc {
    margin: 0;
    font-size: .83rem;
    color: #555;
    line-height: 1.45;
  }

  .menu-item__includes {
    margin: 0;
    padding-left: 16px;
    font-size: .8rem;
    color: #6c3eb8;
    font-style: italic;
  }

  .menu-item__price {
    margin-top: auto;
    padding-top: 8px;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .price--original {
    font-size: .82rem;
    color: #aaa;
    text-decoration: line-through;
  }

  .price--final {
    font-size: 1.05rem;
    font-weight: 700;
    color: #e53935;
  }
</style>
